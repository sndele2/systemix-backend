ENVIRONMENT=local
TWILIO_SIGNATURE_MODE=log
PUBLIC_BASE_URL=https://api.sean-ndele.workers.dev
BUSINESS_FORWARD_NUMBER=+1XXXXXXXXXX
OWNER_NOTIFICATION_NUMBER=+1XXXXXXXXXX
MISSED_CALL_TIMEOUT_SECONDS=20
TEXTBELT_API_KEY=your-textbelt-key
SMTP_EMAIL=alerts@systemix.ai
CLIENT_PHONE=2179912895
## GTM local SMTP test settings
## Paste your real values into cloudflare workers/api-main/api/.dev.vars
INTERNAL_AUTH_KEY=REPLACE_ME_INTERNAL_AUTH_KEY
# Internal auth bootstrap seed for the first owner user.
INTERNAL_INBOX_PASSWORD=REPLACE_ME_INTERNAL_OWNER_PASSWORD
SESSION_SECRET=REPLACE_ME_SESSION_SECRET_AT_LEAST_32_CHARS
ALLOWED_ORIGIN=https://your-app.lovable.app
GTM_DRY_RUN=true
GTM_FROM_EMAIL=REPLACE_ME_GTM_FROM_EMAIL
GTM_FROM_NAME=Systemix
GTM_MAX_TOUCHES=3
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME_SMTP_USER
SMTP_PASS=REPLACE_ME_SMTP_PASS
GTM_ADMIN_KEY=REPLACE_ME_GTM_ADMIN_KEY
## GTM Outlook reply inbox settings
## Use real values only in cloudflare workers/api-main/api/.dev.vars or Wrangler secrets.
GRAPH_TENANT_ID=REPLACE_ME_GRAPH_TENANT_ID
GRAPH_CLIENT_ID=REPLACE_ME_GRAPH_CLIENT_ID
GRAPH_CLIENT_SECRET=REPLACE_ME_GRAPH_CLIENT_SECRET
GRAPH_MAILBOX_UPN=REPLACE_ME_GRAPH_MAILBOX_UPN
